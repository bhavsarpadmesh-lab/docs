{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "InboundSage",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#4a6b3e",
    "light": "#e8f0e3",
    "dark": "#2d4226"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.inboundsage.com"
      },
      {
        "label": "Status",
        "href": "https://status.inboundsage.com"
      },
      {
        "label": "Support",
        "href": "mailto:support@inboundsage.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.inboundsage.com/api-keys"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/wabas", "concepts/templates", "concepts/contacts"]
          },
          {
            "group": "Messages",
            "pages": ["api-reference/messages/send"]
          },
          {
            "group": "Campaigns",
            "pages": [
              "api-reference/campaigns/create",
              "api-reference/campaigns/activate",
              "api-reference/campaigns/stats",
              "api-reference/campaigns/recipients"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/register",
              "api-reference/webhooks/events",
              "api-reference/webhooks/verify-signature"
            ]
          },
          {
            "group": "Reference",
            "pages": ["errors", "rate-limits"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://inboundsage.com"
    }
  }
}
